#!/usr/bin/env bash
# cd — working-file tools for Culinary Dash
#
# LAYOUT (since the readsafe/split commit):
#   culinary-dash.src.html  <- YOU EDIT THIS. ~204KB, no blobs, safe to grep/read.
#   art/*.b64               <- 22 sprite blobs, ~803KB. NEVER read these.
#   culinary-dash.html      <- BUILT artifact. Ships to her. Do not hand-edit.
#
# src and built file have IDENTICAL line numbers (each blob = one marker line),
# so any line ref works in both.
#
# Usage:
#   docs/tools/cd grep <pattern>   # grep the src (safe)
#   docs/tools/cd show <a> <b>     # print src lines a..b
#   docs/tools/cd build            # src + art -> culinary-dash.html
#   docs/tools/cd test             # build, then run the harness
#   docs/tools/cd script           # build + extract JS for the harness
#   docs/tools/cd map              # art inventory + size budget
#
# Golden rule: never cat/grep culinary-dash.html or art/. That's what killed
# sessions ("response incomplete" / "making room for more conversation").

set -euo pipefail
SRC="${SRC:-culinary-dash.src.html}"
OUT="${OUT:-culinary-dash.html}"
W="${W:-400}"

usage() { sed -n '3,25p' "$0"; exit 1; }
[ $# -ge 1 ] || usage

build() { python3 docs/tools/build.py "$@"; }

case "$1" in
  grep)
    [ $# -ge 2 ] || usage
    awk -v p="$2" -v w=$W 'index($0,p)>0 { printf "%6d\t%s\n", NR, substr($0,1,w) }' "$SRC"
    ;;
  show)
    [ $# -ge 3 ] || usage
    awk -v a="$2" -v b="$3" -v w=$W 'NR>=a && NR<=b { printf "%6d\t%s\n", NR, substr($0,1,w) }' "$SRC"
    ;;
  build) build ;;
  script)
    build >/dev/null
    a=$(grep -n "<script>"  "$OUT" | head -1 | cut -d: -f1)
    b=$(grep -n "</script>" "$OUT" | head -1 | cut -d: -f1)
    sed -n "$((a+1)),$((b-1))p" "$OUT"
    ;;
  test)
    build >/dev/null
    WORKDIR="${WORKDIR:-${TMPDIR:-/tmp}/culinary-dash-work}"
    mkdir -p "$WORKDIR"
    "$0" script > "$WORKDIR/game_script.js"
    node -c "$WORKDIR/game_script.js" && echo "syntax OK"
    GAME_SCRIPT="$WORKDIR/game_script.js" node docs/harness.js
    ;;
  map)
    printf "%-28s %10s\n" "ART BLOB" "CHARS"
    for f in art/*.b64; do printf "%-28s %10d\n" "$(basename "$f")" "$(wc -c < "$f")"; done
    s=$(cat art/*.b64 | wc -c); w=$(wc -c < "$SRC"); o=$( [ -f "$OUT" ] && wc -c < "$OUT" || echo 0 )
    echo
    echo "src  (you work here) : $w chars (~$((w/4)) tokens)"
    echo "art  (never read)    : $s chars (~$((s/4)) tokens)"
    echo "built (ships to her) : $o chars"
    echo
    echo "Adding art grows art/ ONLY. The src stays flat — that's the point."
  ;;
  *) usage ;;
esac
