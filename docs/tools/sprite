#!/usr/bin/env python3
"""sprite — PixelLab.ai pixel-art generation for Culinary Dash.

Wraps the PixelLab v2 REST API (https://api.pixellab.ai/v2). Pure stdlib, no pip deps —
same house rule as build.py. The API key is read from .pixellab.key (repo root, chmod 600,
outside the docs bundle) or the PIXELLAB_API_KEY env var. The key is NEVER printed.

  docs/tools/sprite balance                       # remaining generations (free)
  docs/tools/sprite gen <name> "<description>" [--size 64] [--view "low top down"] [--n-directions 4]
  docs/tools/sprite pngs <name>                   # decode saved dirs -> work/sprites/<name>/*.png (free)
  docs/tools/sprite pack <name> [--out PATH]      # -> JS blob for a build marker (free)

Only `gen` spends a generation. It saves the raw response to work/sprites/<name>/response.json
plus one <dir>.b64 data-URI per direction, so pngs/pack never need to re-call the API.

The PixelLab 4-direction response (south/west/east/north) maps 1:1 onto the game's art blob
format: each art/<name>.b64 inlines as a `name:{dir:"data:image/png;base64,..."}` fragment
inside `const CHARS={...}` (see docs/ASSETS.md). Final in-game wiring (dir-name mapping to the
game's own keys, walk frames, scale) is a separate step — this tool gets clean art to art/.
"""
import os, sys, json, base64, ssl, time, urllib.request, urllib.error

BASE = os.environ.get("PIXELLAB_BASE", "https://api.pixellab.ai/v2")
WORK = "work/sprites"
DIRS = {"south", "north", "east", "west",
        "south-east", "south-west", "north-east", "north-west"}


def ssl_ctx():
    # macOS Python often ships without a usable CA bundle (curl works, urllib doesn't).
    # Fall back to the system store so cert verification stays ON.
    ctx = ssl.create_default_context()
    if not ctx.get_ca_certs():
        for p in (os.environ.get("SSL_CERT_FILE"), "/etc/ssl/cert.pem",
                  "/usr/local/etc/openssl/cert.pem"):
            if p and os.path.exists(p):
                ctx.load_verify_locations(p)
                break
    return ctx


def key():
    k = os.environ.get("PIXELLAB_API_KEY")
    if not k:
        for p in (".pixellab.key", os.path.expanduser("~/.pixellab.key")):
            if os.path.exists(p):
                k = open(p).read().strip()
                break
    if not k:
        sys.exit("FATAL: no API key. Set PIXELLAB_API_KEY or create .pixellab.key")
    return k


def call(method, path, body=None):
    url = BASE + path
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method)
    req.add_header("Authorization", "Bearer " + key())
    if data is not None:
        req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=180, context=ssl_ctx()) as r:
            return json.loads(r.read().decode())
    except urllib.error.HTTPError as e:
        detail = e.read().decode(errors="replace")
        sys.exit("HTTP %s %s\n%s" % (e.code, e.reason, detail))
    except urllib.error.URLError as e:
        sys.exit("network error: %s" % e.reason)


def cmd_balance(argv):
    b = call("GET", "/balance")
    sub = b.get("subscription", {})
    cr = b.get("credits", {})
    print("plan       : %s (%s)" % (sub.get("plan", "?"), sub.get("status", "?")))
    print("generations: %s / %s remaining" % (sub.get("generations", "?"), sub.get("total", "?")))
    print("usd credits: $%s" % cr.get("usd", 0))


def _opt(argv, flag, default):
    return argv[argv.index(flag) + 1] if flag in argv else default


def poll(job_id, timeout=300, every=6):
    # PixelLab generation is async: poll the background job until it finishes.
    # A failed job costs nothing, so probing bad params is free.
    waited = 0
    while True:
        j = call("GET", "/background-jobs/" + job_id)
        st = (j.get("status") or "").lower()
        if st in ("completed", "succeeded", "success", "done"):
            return j.get("last_response") or j
        if st in ("failed", "error", "cancelled", "canceled"):
            lr = j.get("last_response") or {}
            sys.exit("generation failed: %s" % (lr.get("error") or lr.get("detail") or st))
        if waited >= timeout:
            sys.exit("timed out after %ss (status=%s)" % (timeout, st))
        time.sleep(every)
        waited += every
        print("  ...%s (%ss)" % (st or "pending", waited))


def fetch_bytes(url):
    # The CDN (backblaze) 403s the default Python-urllib user-agent; a browser UA is fine.
    req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
    with urllib.request.urlopen(req, timeout=120, context=ssl_ctx()) as r:
        return r.read()


def _extract_urls(res):
    # The completed response gives real PNGs on the CDN under storage_urls (dir -> https URL).
    # The inline images.*.base64 field is raw rgba_bytes, NOT a PNG — ignore it. We download the
    # PNGs and store them as data:image/png;base64 URIs, which is exactly the game's blob format.
    urls = res.get("storage_urls") if isinstance(res, dict) else None
    if not urls:
        sys.exit("no storage_urls in response — raw keys: %s" % (list(res.keys()) if isinstance(res, dict) else res))
    return {k: v for k, v in urls.items() if k in DIRS and isinstance(v, str)}


def cmd_gen(argv):
    if len(argv) < 2:
        sys.exit("usage: sprite gen <name> \"<description>\" [--size N] [--view V] [--n-directions 4|8]")
    name, desc = argv[0], argv[1]
    size = int(_opt(argv, "--size", "64"))
    view = _opt(argv, "--view", "low top-down")
    ndir = _opt(argv, "--n-directions", "4")
    ep = "/create-character-with-8-directions" if ndir == "8" else "/create-character-with-4-directions"
    body = {"description": desc, "image_size": {"width": size, "height": size}, "view": view}
    print("generating '%s' (%dx%d, %s, %s-dir) — spends 1 generation on success (failures are free)..." % (
        name, size, size, view, ndir))
    res = call("POST", ep, body)
    job = res.get("background_job_id")
    if job:
        res = poll(job)
    urls = _extract_urls(res)
    if not urls:
        sys.exit("no direction images in response — raw:\n" + json.dumps(res)[:800])
    d = os.path.join(WORK, name)
    os.makedirs(d, exist_ok=True)
    with open(os.path.join(d, "response.json"), "w") as f:
        json.dump(res, f)
    for k, url in sorted(urls.items()):
        png = fetch_bytes(url)                       # real PNG from the CDN
        with open(os.path.join(d, k + ".png"), "wb") as f:
            f.write(png)
        uri = "data:image/png;base64," + base64.b64encode(png).decode()
        with open(os.path.join(d, k + ".b64"), "w") as f:
            f.write(uri)
    print("saved %d directions (%s) -> %s/  [.png + .b64 data-URI]" % (
        len(urls), ", ".join(sorted(urls)), d))
    print("next: sprite pack %s   (-> build blob)   |   PNGs already written for preview" % name)


def _load_dirs(name):
    d = os.path.join(WORK, name)
    if not os.path.isdir(d):
        sys.exit("no saved generation '%s' — run: sprite gen %s ..." % (name, name))
    out = {}
    for fn in sorted(os.listdir(d)):
        if fn.endswith(".b64"):
            out[fn[:-4]] = open(os.path.join(d, fn)).read().strip()
    if not out:
        sys.exit("no direction blobs saved for '%s'" % name)
    return d, out


def cmd_pngs(argv):
    if not argv:
        sys.exit("usage: sprite pngs <name>")
    d, dirs = _load_dirs(argv[0])
    for k, uri in dirs.items():
        raw = uri.split(",", 1)[1] if "," in uri else uri
        with open(os.path.join(d, k + ".png"), "wb") as f:
            f.write(base64.b64decode(raw))
    print("wrote %d PNGs -> %s/*.png" % (len(dirs), d))


def cmd_pack(argv):
    if not argv:
        sys.exit("usage: sprite pack <name> [--out PATH]")
    name = argv[0]
    _, dirs = _load_dirs(name)
    inner = ",".join('%s:%s' % (k, json.dumps(uri)) for k, uri in sorted(dirs.items()))
    blob = "%s:{%s},\n" % (name, inner)
    out = _opt(argv, "--out", None)
    if out:
        with open(out, "w") as f:
            f.write(blob)
        print("wrote %s (%d chars)" % (out, len(blob)))
    else:
        sys.stdout.write(blob)


def main():
    if len(sys.argv) < 2:
        sys.exit(__doc__)
    cmd, argv = sys.argv[1], sys.argv[2:]
    {"balance": cmd_balance, "gen": cmd_gen, "pngs": cmd_pngs, "pack": cmd_pack}.get(
        cmd, lambda a: sys.exit(__doc__))(argv)


if __name__ == "__main__":
    main()
